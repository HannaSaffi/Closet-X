# ============================================================================
# Closet-X Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to git!
# ============================================================================
# Closet-X Environment Configuration Template
# ============================================================================

# DATABASE
MONGODB_URI=mongodb://closetxuser:supersecurepassword@localhost:27017/closetx?authSource=admin

# MESSAGE QUEUE
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT AUTHENTICATION
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-this
JWT_EXPIRATION=7d

# LOCAL FILE STORAGE (for images)
UPLOAD_DIR=./uploads

# WEATHER API
OPENWEATHER_API_KEY=your_openweather_api_key
WEATHER_PROVIDER=openweather

# AI SERVICES
GOOGLE_VISION_API_KEY=your_google_vision_api_key
CLARIFAI_PAT=your_clarifai_personal_access_token
OLLAMA_HOST=http://localhost:11434

# SERVICE PORTS
USER_SERVICE_PORT=3001
OUTFIT_SERVICE_PORT=3002
WARDROBE_SERVICE_PORT=3003

# CORS
CORS_ORIGIN=http://localhost:5173

# NODE ENVIRONMENT
NODE_ENV=development